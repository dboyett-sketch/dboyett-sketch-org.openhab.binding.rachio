<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    
    <modelVersion>4.0.0</modelVersion>
    
    <parent>
        <groupId>org.openhab.addons.bundles</groupId>
        <artifactId>org.openhab.addons.reactor.bundles</artifactId>
        <version>5.0.1</version>
        <relativePath>../pom.xml</relativePath>
    </parent>
    
    <artifactId>org.openhab.binding.rachio</artifactId>
    <packaging>bundle</packaging>
    
    <name>openHAB Add-ons :: Bundles :: Rachio Binding</name>
    <description>Binding for Rachio smart irrigation controllers</description>
    
    <properties>
        <gson.version>2.10.1</gson.version>
        <servlet-api.version>4.0.1</servlet-api.version>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <maven.compiler.release>17</maven.compiler.release>
        <bundle.namespace>org.openhab.binding.rachio</bundle.namespace>
    </properties>
    
    <!-- MINIMAL dependencies - parent provides OpenHAB core -->
    <dependencies>
        <!-- Gson for JSON parsing (OpenHAB provides it) -->
        <dependency>
            <groupId>com.google.code.gson</groupId>
            <artifactId>gson</artifactId>
            <version>${gson.version}</version>
            <scope>provided</scope>
        </dependency>
        
        <!-- Servlet API for webhooks (provided by OpenHAB) -->
        <dependency>
            <groupId>javax.servlet</groupId>
            <artifactId>javax.servlet-api</artifactId>
            <version>${servlet-api.version}</version>
            <scope>provided</scope>
        </dependency>
        
        <!-- OSGi annotations -->
        <dependency>
            <groupId>org.osgi</groupId>
            <artifactId>org.osgi.service.component.annotations</artifactId>
            <version>1.5.0</version>
            <scope>provided</scope>
        </dependency>
        
        <!-- OSGi HTTP service -->
        <dependency>
            <groupId>org.osgi</groupId>
            <artifactId>org.osgi.service.http</artifactId>
            <version>1.2.1</version>
            <scope>provided</scope>
        </dependency>
    </dependencies>
    
    <build>
        <plugins>
            <!-- Compiler plugin for Java 17 compatibility -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.14.1</version>
                <configuration>
                    <source>${maven.compiler.source}</source>
                    <target>${maven.compiler.target}</target>
                    <release>${maven.compiler.release}</release>
                    <encoding>UTF-8</encoding>
                </configuration>
            </plugin>
            
            <!-- Bundle plugin for OSGi manifest generation -->
            <plugin>
                <groupId>org.apache.felix</groupId>
                <artifactId>maven-bundle-plugin</artifactId>
                <version>5.1.4</version>
                <extensions>true</extensions>
                <configuration>
                    <instructions>
                        <!-- Basic bundle information -->
                        <Bundle-SymbolicName>${bundle.namespace}</Bundle-SymbolicName>
                        <Bundle-Name>${project.name}</Bundle-Name>
                        <Bundle-Description>${project.description}</Bundle-Description>
                        <Bundle-Vendor>openHAB Community</Bundle-Vendor>
                        <Bundle-Version>${project.version}</Bundle-Version>
                        <Bundle-Category>binding</Bundle-Category>
                        
                        <!-- Fix for osgi.ee requirement - OpenHAB 5.x uses Java 17 -->
                        <Require-Capability>osgi.ee;filter:="(&amp;(osgi.ee=JavaSE)(version=17))"</Require-Capability>
                        
                        <!-- Import packages with proper version ranges -->
                        <Import-Package>
                            org.openhab.core.*;version="[5.0,6)",
                            org.openhab.core.config.*;version="[5.0,6)",
                            org.openhab.core.thing.*;version="[5.0,6)",
                            org.openhab.core.library.*;version="[5.0,6)",
                            org.openhab.core.io.net.http;version="[5.0,6)",
                            org.openhab.core.common;version="[5.0,6)",
                            com.google.gson;version="[2.8,3)",
                            com.google.gson.reflect,
                            javax.servlet,
                            javax.servlet.http,
                            org.osgi.framework;version="[1.10,2)",
                            org.osgi.service.component;version="[1.5,2)",
                            org.osgi.service.component.annotations;version="[1.5,2)",
                            org.osgi.service.http;version="[1.2,2)",
                            org.osgi.util.tracker;version="[1.5,2)",
                            org.slf4j;version="[1.7,2)",
                            *
                        </Import-Package>
                        
                        <!-- Explicitly exclude Jetty packages (we use Java HttpClient) -->
                        <Import-Package>
                            !org.eclipse.jetty.*,
                            *
                        </Import-Package>
                        
                        <!-- Export our packages -->
                        <Export-Package>
                            ${bundle.namespace}.*;version="${project.version}"
                        </Export-Package>
                        
                        <!-- Enable Declarative Services annotations -->
                        <_dsannotations>*</_dsannotations>
                        
                        <!-- Don't embed any dependencies - use provided scope -->
                        <Embed-Dependency>!*</Embed-Dependency>
                        <Embed-Transitive>false</Embed-Transitive>
                        <Embed-Directory>lib</Embed-Directory>
                        
                        <!-- Don't include dependency versions in manifest -->
                        <Embed-StripGroup>true</Embed-StripGroup>
                        <Embed-StripVersion>true</Embed-StripVersion>
                        
                        <!-- Addon metadata for OpenHAB -->
                        <Openhab-Binding>true</Openhab-Binding>
                        <Openhab-Runtime>openhab</Openhab-Runtime>
                    </instructions>
                </configuration>
            </plugin>
            
            <!-- Copy resources for OpenHAB -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-resources-plugin</artifactId>
                <version>3.4.0</version>
                <executions>
                    <execution>
                        <id>copy-resources</id>
                        <phase>process-resources</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>${project.build.outputDirectory}</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>src/main/resources</directory>
                                    <includes>
                                        <include>OH-INF/**</include>
                                        <include>**/*.properties</include>
                                        <include>**/*.xml</include>
                                    </includes>
                                    <filtering>false</filtering>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
