<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    
    <modelVersion>4.0.0</modelVersion>
    
    <parent>
        <groupId>org.openhab.addons.bundles</groupId>
        <artifactId>org.openhab.addons.reactor.bundles</artifactId>
        <version>5.0.1</version>
        <relativePath>../pom.xml</relativePath>
    </parent>
    
    <artifactId>org.openhab.binding.rachio</artifactId>
    <packaging>bundle</packaging>
    
    <name>openHAB Add-ons :: Bundles :: Rachio Binding</name>
    <description>Binding for Rachio smart irrigation controllers</description>
    
    <properties>
        <gson.version>2.10.1</gson.version>
        <servlet-api.version>4.0.1</servlet-api.version>
    </properties>
    
    <!-- MINIMAL dependencies - parent provides OpenHAB core -->
    <dependencies>
        <!-- Gson for JSON parsing -->
        <dependency>
            <groupId>com.google.code.gson</groupId>
            <artifactId>gson</artifactId>
            <version>${gson.version}</version>
            <scope>provided</scope>
        </dependency>
        
        <!-- Servlet API for webhooks (provided by OpenHAB) -->
        <dependency>
            <groupId>javax.servlet</groupId>
            <artifactId>javax.servlet-api</artifactId>
            <version>${servlet-api.version}</version>
            <scope>provided</scope>
        </dependency>
        
        <!-- OSGi Component Annotations -->
        <dependency>
            <groupId>org.osgi</groupId>
            <artifactId>org.osgi.service.component.annotations</artifactId>
            <version>1.5.0</version>
            <scope>provided</scope>
        </dependency>
    </dependencies>
    
    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.felix</groupId>
                <artifactId>maven-bundle-plugin</artifactId>
                <version>5.1.4</version>
                <extensions>true</extensions>
                <configuration>
                    <instructions>
                        <Bundle-SymbolicName>org.openhab.binding.rachio</Bundle-SymbolicName>
                        <Bundle-Name>openHAB Add-ons :: Bundles :: Rachio Binding</Bundle-Name>
                        <Bundle-Description>Binding for Rachio smart irrigation controllers</Bundle-Description>
                        <Bundle-Vendor>openHAB Community</Bundle-Vendor>
                        <Bundle-Version>${project.version}</Bundle-Version>
                        <Bundle-Category>binding</Bundle-Category>
                        
                        <!-- Important: Don't import Jetty packages since we're using Java HttpClient -->
                        <Import-Package>
                            org.openhab.core.*;version="[5.0,6)",
                            com.google.gson;version="[2.8,3)",
                            com.google.gson.reflect,
                            javax.servlet,
                            javax.servlet.http,
                            org.osgi.service.component.annotations;version="[1.5,2)",
                            org.osgi.service.http,
                            *
                        </Import-Package>
                        
                        <!-- Don't import optional packages -->
                        <Import-Package>
                            !org.eclipse.jetty.*,
                            *
                        </Import-Package>
                        
                        <Export-Package>
                            org.openhab.binding.rachio.*;version="${project.version}"
                        </Export-Package>
                        
                        <_dsannotations>*</_dsannotations>
                        
                        <!-- Don't embed any dependencies -->
                        <Embed-Dependency>!*</Embed-Dependency>
                        <Embed-Transitive>false</Embed-Transitive>
                    </instructions>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
