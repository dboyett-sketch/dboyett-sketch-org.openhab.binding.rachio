<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>org.openhab.addons.bundles</groupId>
    <artifactId>org.openhab.binding.rachio</artifactId>
    <version>5.0.0-SNAPSHOT</version>
    <packaging>bundle</packaging>

    <name>openHAB Add-ons :: Bundles :: Rachio Binding</name>
    <description>Rachio irrigation system binding for openHAB</description>

    <parent>
        <groupId>org.openhab.addons.reactor</groupId>
        <artifactId>openhab-addons</artifactId>
        <version>5.0.0</version>
        <relativePath/>
    </parent>

    <properties>
        <!-- Java 17 for OpenHAB 5.x -->
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <openhab.version>[5.0.0,6.0.0)</openhab.version>
        
        <!-- Standard binding properties -->
        <jar.manifest.export-package>org.openhab.binding.rachio.*</jar.manifest.export-package>
        <jar.manifest.import-package>
            !javax.annotation,
            org.eclipse.jdt.annotation.*;version="[2.2,3)",
            org.openhab.core.*;version="${openhab.version}",
            org.openhab.core.config.*;version="${openhab.version}",
            org.openhab.core.config.discovery.*;version="${openhab.version}",
            org.openhab.core.io.net.http.*;version="${openhab.version}",
            org.openhab.core.library.*;version="${openhab.version}",
            org.openhab.core.library.types.*;version="${openhab.version}",
            org.openhab.core.thing.*;version="${openhab.version}",
            org.openhab.core.thing.binding.*;version="${openhab.version}",
            org.openhab.core.thing.type.*;version="${openhab.version}",
            org.openhab.core.types.*;version="${openhab.version}",
            org.openhab.core.automation.*;version="${openhab.version}",
            org.osgi.service.component.*;version="[1.5,2)",
            org.osgi.service.http.*;version="[1.2,2)",
            org.osgi.service.jaxrs.*;version="[1.0,2)",
            org.osgi.service.event.*;version="[1.4,2)",
            javax.servlet.*;version="[3.1,4)",
            javax.servlet.http.*;version="[3.1,4)",
            com.google.gson.*;version="[2.8,3)",
            org.slf4j.*;version="[1.7,2)",
            *
        </jar.manifest.import-package>
        
        <!-- Bundle manifest headers -->
        <jar.manifest.attributes>
            <Bundle-SymbolicName>${project.artifactId}</Bundle-SymbolicName>
            <Bundle-Name>${project.name}</Bundle-Name>
            <Bundle-Version>${project.version}</Bundle-Version>
            <Bundle-Vendor>openHAB Foundation</Bundle-Vendor>
            <Bundle-ActivationPolicy>lazy</Bundle-ActivationPolicy>
            <Bundle-RequiredExecutionEnvironment>JavaSE-17</Bundle-RequiredExecutionEnvironment>
            <Require-Capability>
                osgi.extender;filter:="(osgi.extender=osgi.serviceloader.registrar)",
                osgi.contract;osgi.contract=JavaServlet;filter:="(&(osgi.contract=JavaServlet)(version=3.1))",
                osgi.serviceloader;filter:="(osgi.serviceloader=org.openhab.core.thing.binding.ThingHandlerFactory)";cardinality:=multiple,
                osgi.serviceloader;filter:="(osgi.serviceloader=org.openhab.core.config.discovery.DiscoveryService)";cardinality:=multiple
            </Require-Capability>
            <Provide-Capability>
                osgi.serviceloader;osgi.serviceloader=org.openhab.core.thing.binding.ThingHandlerFactory,
                osgi.serviceloader;osgi.serviceloader=org.openhab.core.config.discovery.DiscoveryService
            </Provide-Capability>
        </jar.manifest.attributes>
    </properties>

    <dependencies>
        <!-- OpenHAB Core Dependencies -->
        <dependency>
            <groupId>org.openhab.core</groupId>
            <artifactId>org.openhab.core</artifactId>
            <version>${openhab.version}</version>
            <scope>provided</scope>
        </dependency>
        
        <dependency>
            <groupId>org.openhab.core</groupId>
            <artifactId>org.openhab.core.thing</artifactId>
            <version>${openhab.version}</version>
            <scope>provided</scope>
        </dependency>
        
        <dependency>
            <groupId>org.openhab.core</groupId>
            <artifactId>org.openhab.core.config.discovery</artifactId>
            <version>${openhab.version}</version>
            <scope>provided</scope>
        </dependency>
        
        <dependency>
            <groupId>org.openhab.core</groupId>
            <artifactId>org.openhab.core.io.net.http</artifactId>
            <version>${openhab.version}</version>
            <scope>provided</scope>
        </dependency>
        
        <!-- OSGi R7 Declarative Services Annotations -->
        <dependency>
            <groupId>org.osgi</groupId>
            <artifactId>org.osgi.service.component</artifactId>
            <version>1.5.0</version>
            <scope>provided</scope>
        </dependency>
        
        <dependency>
            <groupId>org.osgi</groupId>
            <artifactId>org.osgi.service.component.annotations</artifactId>
            <version>1.5.0</version>
            <scope>provided</scope>
        </dependency>
        
        <!-- OSGi HTTP Whiteboard for Servlet Registration -->
        <dependency>
            <groupId>org.osgi</groupId>
            <artifactId>org.osgi.service.http.whiteboard</artifactId>
            <version>1.1.1</version>
            <scope>provided</scope>
        </dependency>
        
        <dependency>
            <groupId>org.osgi</groupId>
            <artifactId>org.osgi.service.jaxrs</artifactId>
            <version>1.0.0</version>
            <scope>provided</scope>
        </dependency>
        
        <!-- Servlet API (provided by runtime) -->
        <dependency>
            <groupId>javax.servlet</groupId>
            <artifactId>javax.servlet-api</artifactId>
            <version>3.1.0</version>
            <scope>provided</scope>
        </dependency>
        
        <!-- JSON Processing -->
        <dependency>
            <groupId>com.google.code.gson</groupId>
            <artifactId>gson</artifactId>
            <version>2.10.1</version>
            <scope>provided</scope>
        </dependency>
        
        <!-- Logging -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
            <version>2.0.9</version>
            <scope>provided</scope>
        </dependency>
        
        <!-- Null Annotations -->
        <dependency>
            <groupId>org.eclipse.jdt</groupId>
            <artifactId>org.eclipse.jdt.annotation</artifactId>
            <version>2.2.800</version>
            <scope>provided</scope>
        </dependency>
        
        <!-- Testing Dependencies -->
        <dependency>
            <groupId>junit</groupId>
            <artifactId>junit</artifactId>
            <version>4.13.2</version>
            <scope>test</scope>
        </dependency>
        
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
            <version>5.7.0</version>
            <scope>test</scope>
        </dependency>
        
        <dependency>
            <groupId>org.openhab.core</groupId>
            <artifactId>org.openhab.core.test</artifactId>
            <version>${openhab.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- Maven Bundle Plugin for OSGi -->
            <plugin>
                <groupId>org.apache.felix</groupId>
                <artifactId>maven-bundle-plugin</artifactId>
                <version>5.1.9</version>
                <extensions>true</extensions>
                <configuration>
                    <instructions>
                        <Bundle-SymbolicName>${project.artifactId}</Bundle-SymbolicName>
                        <Bundle-Name>${project.name}</Bundle-Name>
                        <Bundle-Version>${project.version}</Bundle-Version>
                        <Bundle-Vendor>openHAB Foundation</Bundle-Vendor>
                        <Bundle-ActivationPolicy>lazy</Bundle-ActivationPolicy>
                        <Bundle-RequiredExecutionEnvironment>JavaSE-17</Bundle-RequiredExecutionEnvironment>
                        <Export-Package>${jar.manifest.export-package}</Export-Package>
                        <Import-Package>${jar.manifest.import-package}</Import-Package>
                        <_include>-osgi.bundle</_include>
                        <_noee>true</_noee>
                        <_removeheaders>
                            Built-By,Tool,Created-By,Include-Resource,Private-Package,
                            Ignore-Package,Bnd-LastModified
                        </_removeheaders>
                    </instructions>
                </configuration>
            </plugin>
            
            <!-- Compiler Plugin for Java 17 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.11.0</version>
                <configuration>
                    <source>17</source>
                    <target>17</target>
                    <encoding>UTF-8</encoding>
                    <showWarnings>true</showWarnings>
                    <showDeprecation>true</showDeprecation>
                    <compilerArgs>
                        <arg>-Xlint:all</arg>
                        <arg>-Werror</arg>
                    </compilerArgs>
                </configuration>
            </plugin>
            
            <!-- Resources Plugin -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-resources-plugin</artifactId>
                <version>3.3.1</version>
                <configuration>
                    <encoding>UTF-8</encoding>
                </configuration>
            </plugin>
            
            <!-- Surefire Test Plugin -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.1.2</version>
                <configuration>
                    <skipTests>false</skipTests>
                    <failIfNoTests>false</failIfNoTests>
                    <includes>
                        <include>**/*Test.java</include>
                        <include>**/*IT.java</include>
                    </includes>
                </configuration>
            </plugin>
            
            <!-- JaCoCo Code Coverage -->
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>0.8.10</version>
                <executions>
                    <execution>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>report</id>
                        <phase>test</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <!-- Development Profile -->
        <profile>
            <id>development</id>
            <activation>
                <property>
                    <name>env.DEVELOPMENT</name>
                </property>
            </activation>
            <properties>
                <skipTests>false</skipTests>
            </properties>
        </profile>
        
        <!-- Production Profile -->
        <profile>
            <id>production</id>
            <activation>
                <property>
                    <name>env.PRODUCTION</name>
                </property>
            </activation>
            <properties>
                <skipTests>true</skipTests>
            </properties>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-javadoc-plugin</artifactId>
                        <version>3.6.0</version>
                        <executions>
                            <execution>
                                <id>attach-javadocs</id>
                                <goals>
                                    <goal>jar</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-source-plugin</artifactId>
                        <version>3.3.0</version>
                        <executions>
                            <execution>
                                <id>attach-sources</id>
                                <goals>
                                    <goal>jar</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>

    <repositories>
        <!-- OpenHAB Repository -->
        <repository>
            <id>openhab-releases</id>
            <url>https://openhab.jfrog.io/artifactory/libs-release</url>
        </repository>
        <repository>
            <id>openhab-snapshots</id>
            <url>https://openhab.jfrog.io/artifactory/libs-snapshot</url>
            <snapshots>
                <enabled>true</enabled>
            </snapshots>
        </repository>
        
        <!-- Maven Central -->
        <repository>
            <id>central</id>
            <url>https://repo.maven.apache.org/maven2</url>
        </repository>
        
        <!-- OSGi Repository -->
        <repository>
            <id>osgi-releases</id>
            <url>https://repo.osgi.org/maven2/releases</url>
        </repository>
    </repositories>

    <pluginRepositories>
        <pluginRepository>
            <id>openhab-releases</id>
            <url>https://openhab.jfrog.io/artifactory/libs-release</url>
        </pluginRepository>
        <pluginRepository>
            <id>openhab-snapshots</id>
            <url>https://openhab.jfrog.io/artifactory/libs-snapshot</url>
            <snapshots>
                <enabled>true</enabled>
            </snapshots>
        </pluginRepository>
    </pluginRepositories>
</project>
